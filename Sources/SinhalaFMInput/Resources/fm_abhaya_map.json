    "splitVowels": [
        {
            "triggerKey": "&",
            "leftPart": "e",
            "rightPart": "a",
            "description": "ො - O-kombuva (kombuva + aela-pilla wrapping consonant)"
        },
        {
            "triggerKey": "*",
            "leftPart": "E",
            "rightPart": "a",
            "description": "ෝ - Diga O-kombuva (diga-kombuva + aela-pilla wrapping consonant)"
        },
        {
            "triggerKey": "^",
            "leftPart": "e",
            "rightPart": "A",
            "description": "ෞ - Au-kombuva (kombuva + au-right wrapping consonant)"
        }
    ],
    "conjuncts": [
        {
            "inputSequence": ["k", "'", "w"],
            "outputChar": "@",
            "description": "ක්ෂ - Ksha conjunct (ka + hal + sha)"
        },
        {
            "inputSequence": [";", "'", ";"],
            "outputChar": "#",
            "description": "ත්ත - Ththa conjunct (ta + hal + ta)"
        },
        {
            "inputSequence": ["n", "'", "o"],
            "outputChar": "$",
            "description": "න්ද - Nda conjunct (na + hal + da)"
        },
        {
            "inputSequence": ["n", "'", "n"],
            "outputChar": "%",
            "description": "න්න - Nna conjunct (na + hal + na)"
